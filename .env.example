# GitHub Organization Configuration
# REQUIRED: Replace with your GitHub organization name (for org audits)
GITHUB_ORG=your-org-name

# GitHub Personal Username (for auditing personal repos)
# REQUIRED: Replace with your GitHub username (for personal audits)
# NOTE: The script will prioritize GITHUB_ORG if both are set
GITHUB_USERNAME=your-username

# GitHub Personal Access Token (PAT)
# REQUIRED: Generate at https://github.com/settings/tokens
# Required scopes: repo:read, read:org
GITHUB_TOKEN=ghp_yourtoken...

# Optional: Auto-create issues in non-compliant repos
# Set to 'true' to enable automatic issue creation
CREATE_ISSUES=false
